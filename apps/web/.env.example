# Copy this file to apps/web/.env.local and fill in real values.
# .env.local is git-ignored (see .gitignore) — never commit it.
# Anything prefixed NEXT_PUBLIC_ is shipped to the browser — only put
# values there that are safe to expose (publishable keys, public URLs).

NEXT_PUBLIC_API_URL=http://localhost:3001

# === Auth (Supabase) — Sprint 2 ===
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Payments (Stripe) — Sprint 2 ===
# Publishable (= public) key from: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Monitoring — Sprint 2 ===
# From: Sentry → your Next.js project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# From: PostHog → Settings → Project → API Keys → "Project API Key"
# (not the personal API key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
