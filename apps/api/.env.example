# Copy this file to apps/api/.env and fill in real values.
# .env is git-ignored (see .gitignore) — never commit it.

# === Server ===
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# === Database ===
# For local Docker dev — leave as-is.
# For Supabase Postgres, replace with your Supabase Connection-Pooling URL
# from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the POOLER URL for the API (handles transient connections).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cryptotrader?schema=public"

# === Cache & Queues ===
REDIS_URL="redis://localhost:6379"

# === Auth (Supabase) — Sprint 2 ===
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From: Supabase Dashboard → Project Settings → Webhooks
SUPABASE_WEBHOOK_SECRET=
# From: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# === Payments (Stripe) — Sprint 2 ===
# From: Stripe Dashboard → Developers → API keys → "Secret key" (test mode)
STRIPE_SECRET_KEY=
# Generated when you create a webhook endpoint in Sprint 2:
# Stripe Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=
# Generated when Sprint 2's setup-stripe.ts script creates the products
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TRADER_MONTHLY=
STRIPE_PRICE_TRADER_YEARLY=

# === On-Chain — Sprint 3 ===
# ALCHEMY_API_KEY=
# ZERION_API_KEY=
# HELIUS_API_KEY=

# === Prices — Sprint 3 ===
# COINGECKO_API_KEY=

# === LLM — Sprint 8 ===
# From: https://platform.claude.com/settings/keys
# ANTHROPIC_API_KEY=

# === Security — generate via: openssl rand -hex 32 ===
ENCRYPTION_KEY=

# === Monitoring ===
# From: Sentry → your project → Settings → Client Keys (DSN) — use the EU one
SENTRY_DSN=

# === Affiliate IDs (from the existing live site, already wired) ===
BINANCE_AFFILIATE_ID=376216722
BYBIT_AFFILIATE_ID=AYOLGJP
MEXC_AFFILIATE_ID=mexc-3nPe1
